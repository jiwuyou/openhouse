<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F172A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/browser_panel_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/browser_panel_title"
            android:textColor="#F8FAFC"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/browser_page_title_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:gravity="end"
            android:text="@string/browser_page_title_default"
            android:textColor="#94A3B8"
            android:textSize="12sp" />
    </LinearLayout>

    <mozilla.components.browser.toolbar.BrowserToolbar
        android:id="@+id/browser_toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#111827"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/browser_quick_actions_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp"
        android:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browser_quick_new_tab_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="@string/browser_quick_new_tab" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browser_quick_tabs_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="@string/browser_quick_tabs" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browser_quick_history_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="@string/browser_quick_history" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browser_quick_bookmark_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:text="@string/browser_quick_bookmark" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/browser_tab_strip_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0B1220"
        android:paddingHorizontal="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/browser_tab_strip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/browser_content_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/browser_web_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/browser_tabs_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="6dp"
        android:background="#0F172A"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/browser_tabs_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/browser_tabs_title"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browser_tabs_new_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/browser_tabs_new" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browser_tabs_done_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:text="@string/browser_tabs_done" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browser_tabs_history_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="@string/browser_menu_history" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browser_tabs_bookmarks_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="@string/browser_menu_bookmarks" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/browser_tabs_toggle_bookmark_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minWidth="0dp"
            android:text="@string/browser_menu_add_bookmark" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="176dp"
            android:layout_marginTop="12dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/browser_tabs_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/browser_library_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="6dp"
        android:background="#0F172A"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/browser_library_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/browser_history_title"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browser_library_done_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/browser_tabs_done" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="176dp"
            android:layout_marginTop="12dp"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/browser_library_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <TextView
        android:id="@+id/browser_status_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F172A"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="@string/browser_status_ready"
        android:textColor="#94A3B8"
        android:textSize="11sp" />

</LinearLayout>
