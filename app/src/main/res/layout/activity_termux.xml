<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/global_mode_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#101828"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/global_app_title_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/global_app_title"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mode_title_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/mode_title_daily"
                    android:textColor="#D0D5DD"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mode_summary_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/mode_summary_daily"
                    android:textColor="#98A2B3"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/global_mode_button_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mode_daily_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="@string/mode_button_daily" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mode_dev_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="@string/mode_button_dev" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mode_automation_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:text="@string/mode_button_automation" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/activity_termux_host_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/workspace_browser_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="3dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:background="@android:color/black"
            android:orientation="vertical"
            android:visibility="gone" />

        <RelativeLayout
            android:id="@+id/activity_termux_root_relative_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="3dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:orientation="vertical">

            <androidx.drawerlayout.widget.DrawerLayout
                android:id="@+id/drawer_layout"
                android:layout_width="match_parent"
                android:layout_alignParentTop="true"
                android:layout_above="@+id/terminal_toolbar_view_pager"
                android:layout_height="match_parent">

                <com.termux.view.TerminalView
                    android:id="@+id/terminal_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:defaultFocusHighlightEnabled="false"
                    android:focusableInTouchMode="true"
                    android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                    android:scrollbars="vertical"
                    tools:ignore="UnusedAttribute" />

                <LinearLayout
                    android:id="@+id/left_drawer"
                    android:layout_width="240dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:choiceMode="singleChoice"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:descendantFocusability="blocksDescendants"
                    android:orientation="vertical"
                    android:background="?attr/termuxActivityDrawerBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageButton
                            android:id="@+id/settings_button"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_settings"
                            android:background="@null"
                            android:contentDescription="@string/action_open_settings"
                            app:tint="?attr/termuxActivityDrawerImageTint" />
                    </LinearLayout>

                    <ListView
                        android:id="@+id/terminal_sessions_list"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_gravity="top"
                        android:layout_weight="1"
                        android:choiceMode="singleChoice"
                        android:longClickable="true" />

                    <LinearLayout
                        style="?android:attr/buttonBarStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggle_keyboard_button"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/action_toggle_soft_keyboard" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/new_session_button"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/action_new_session" />
                    </LinearLayout>
                </LinearLayout>

            </androidx.drawerlayout.widget.DrawerLayout>

            <View
                android:id="@+id/terminal_surface_top_inset"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_alignParentTop="true"
                android:background="#0F172A"
                android:visibility="gone" />

            <androidx.viewpager.widget.ViewPager
                android:id="@+id/terminal_toolbar_view_pager"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="37.5dp"
                android:background="@color/black"
                android:layout_alignParentBottom="true" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/control_browser_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="3dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:background="@android:color/black"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/dev_surface_switcher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="12dp"
            android:background="#CC0F172A"
            android:elevation="8dp"
            android:orientation="horizontal"
            android:padding="4dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dev_surface_preview_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="72dp"
                android:text="@string/dev_surface_preview" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dev_surface_terminal_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:minWidth="72dp"
                android:text="@string/dev_surface_terminal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dev_surface_controller_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:minWidth="88dp"
                android:text="@string/dev_surface_controller" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dev_terminal_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginTop="84dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/dev_terminal_action_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#D90F172A"
                android:elevation="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dev_terminal_sessions_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="72dp"
                    android:text="@string/dev_terminal_sessions" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dev_terminal_new_session_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:minWidth="64dp"
                    android:text="@string/dev_terminal_new_session" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dev_terminal_toggle_button"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:elevation="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="@string/dev_terminal_toggle" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/global_status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/status_left_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/status_left_default"
            android:textColor="#98A2B3"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/status_right_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_right_default"
            android:textColor="#D0D5DD"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
